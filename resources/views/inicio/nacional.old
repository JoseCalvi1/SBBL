                <div id="game-marker"></div>
            </div>

            <button id="btn-game-action" class="btn-cyber" style="padding: 15px 40px; font-size: 1.2rem; margin-top: 0;" onclick="toggleGame()">INICIAR ENTRENAMIENTO</button>
